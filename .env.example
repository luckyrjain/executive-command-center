# Executive Command Center local development environment
ECC_ENV=development
ECC_DATABASE_URL=postgresql+psycopg://ecc:ecc@localhost:5432/ecc
ECC_SESSION_SECRET=replace-with-a-random-secret-at-least-32-characters-long
ECC_CORS_ORIGINS=http://localhost:5173
# Set to the number of trusted reverse proxies/load balancers in front of
# the backend (e.g. 1 for a single nginx/ALB hop) so the mutation rate
# limiter reads the real client IP from X-Forwarded-For. Leave at 0 for
# local development (no proxy in front).
ECC_TRUSTED_PROXY_COUNT=0
# Shared-secret token gating GET /metrics (Authorization: Bearer <token>).
# Optional, but strongly recommended in production -- if unset, /metrics is
# open to anyone who can reach it. Leave unset for local development.
ECC_METRICS_TOKEN=

POSTGRES_DB=ecc
POSTGRES_USER=ecc
POSTGRES_PASSWORD=ecc

# Used by the Vite frontend at build/dev time.
VITE_API_BASE_URL=http://localhost:8000
