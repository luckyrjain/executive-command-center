{"nodes": [{"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design", "label": "Phase 1 Completion Design", "file_type": "document", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_outcome", "label": "Outcome", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Phase 1 completion is defined broadly (full browser workflow, green automated gates, safe production defaults, proven recovery, evidence-matching docs) but explicitly excludes the one-week daily-use validation, because that gate can only be satisfied by elapsed real-world usage, not by code changes."}, {"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_delivery_strategy", "label": "Delivery Strategy", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_frontend_architecture", "label": "Frontend Architecture", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_shared_api_boundary", "label": "Shared API Boundary", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_conflict_and_recovery_behavior", "label": "Conflict and Recovery Behavior", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Optimistic-concurrency conflicts preserve unsaved user input and require an explicit retry rather than silently overwriting a newer version, because silent overwrite risks silent data loss for a user relying on the tool for day-to-day executive tracking."}, {"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_entity_workflows", "label": "Entity Workflows (Tasks, Commitments, Notes, Calendar, Risks, Recommendations)", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_accessibility_and_ux_states", "label": "Accessibility and UX States", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_browser_acceptance", "label": "Browser Acceptance", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_backend_production_hardening", "label": "Backend Production Hardening", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_backup_and_recovery", "label": "Backup and Recovery", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_ci_and_security", "label": "CI and Security", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_performance_evidence", "label": "Performance Evidence", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_operations_and_evidence", "label": "Operations and Evidence", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_documentation_consistency", "label": "Documentation Consistency", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Status vocabulary is fixed (Implemented means code exists with focused proof; Verified means required evidence is recorded; Complete means every exit criterion including daily-use validation is satisfied) so no document can claim broader coverage than the referenced test performs, preventing status drift across the roadmap, implementation status, final acceptance, and release gate documents."}, {"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_error_handling_and_safety", "label": "Error Handling and Safety", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_verification_hierarchy", "label": "Verification Hierarchy", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_non_goals", "label": "Non-goals", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Phase 1 explicitly excludes external connectors, semantic search, autonomous execution, multi-user collaboration, cloud deployment, Phase 2 behavior, and any redesign of frozen backend contracts, keeping the completion scope bounded to hardening and finishing already-scoped work rather than expanding it."}, {"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_completion_boundary", "label": "Completion Boundary", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Implementation is ready for change review once all automated gates pass and release-gate checkboxes are accurately updated, but final Phase 1 closure additionally requires the completed seven-day daily-use record and explicit human approval, preventing an automated-only signoff from being treated as full completion."}, {"id": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_frozen_phase_1_api_contracts", "label": "Frozen Phase 1 API Contracts", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Phase 1 API and lifecycle contracts stay frozen during this hardening work so that completing verification, security, and operational requirements cannot regress or reshape behavior that downstream consumers and tests already depend on."}, {"id": "docs_phases_phase_001_executive_dashboard_mvp", "label": "PHASE-001 Executive Dashboard MVP spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "docs_superpowers_specs_2026_07_16_phase_1_completion_design", "target": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_outcome", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_07_16_phase_1_completion_design", "target": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_delivery_strategy", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-16-phase-1-completion-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_07_16_phase_1_completion_design", "target": "docs_superpowers_specs_2026_07_16_phase_1_completion_design_frontend_architecture", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-16-p