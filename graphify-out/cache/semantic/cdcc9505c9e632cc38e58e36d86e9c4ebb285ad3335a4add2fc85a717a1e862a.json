docs_rfc_003_dp_004_memory_is_permanent", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "docs/RFC-002.md", "source_location": null, "weight": 1.0}, {"source": "docs_rfc_002_ep_005_local_first", "target": "docs_rfc_003_dp_002_local_first", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "docs/RFC-002.md", "source_location": null, "weight": 1.0}], "hyperedges": [{"id": "local_first_principle_across_layers", "label": "Local-First Principle repeated across product, engineering, design and architecture specification layers without direct cross-citation", "nodes": ["docs_rfc_001_principle_1_local_first", "docs_rfc_002_ep_005_local_first", "docs_rfc_003_dp_002_local_first", "docs_adr_adr_0002_local_first_architecture_local_first_architecture"], "relation": "form", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "docs/RFC-002.md"}]}