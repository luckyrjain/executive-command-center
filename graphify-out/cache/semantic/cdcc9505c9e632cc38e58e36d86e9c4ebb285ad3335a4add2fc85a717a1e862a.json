{"nodes": [{"id": "docs_rfc_002_rfc_002", "label": "RFC-002: Engineering Philosophy", "file_type": "document", "source_file": "docs/RFC-002.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_rfc_002_ep_001_specification_before_code", "label": "EP-001 Specification Before Code: development follows Understand->Specify->Review->Implement->Test->Deploy; no behavior-changing PR without spec update", "file_type": "rationale", "source_file": "docs/RFC-002.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_rfc_002_ep_002_simplicity_wins", "label": "EP-002 Simplicity Wins: the simplest solution satisfying a requirement SHALL be preferred; complexity compounds", "file_type": "rationale", "source_file": "docs/RFC-002.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_rfc_002_ep_003_delete_before_add", "label": "EP-003 Delete Before Add: evaluate existing systems before introducing new ones; adding code is easy, removing is difficult", "file_type": "rationale", "source_file": "docs/RFC-002.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_rfc_002_ep_004_ai_is_a_junior_engineer", "label": "EP-004 AI is a Junior Engineer: AI accelerates but does not replace engineering judgment; every AI change needs human review, architectural validation, tests, traceability", "file_type": "rationale", "source_file": "docs/RFC-002.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_rfc_002_ep_005_local_first", "label": "EP-005 Local First: local execution is default for privacy, ownership, latency, resilience, cost; cloud SHALL NOT be mandatory for core workflows", "file_type": "rationale", "source_file": "docs/RFC-002.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_rfc_002_ep_006_explainability_over_intelligence", "label": "EP-006 Explainability Over Intelligence: an explainable recommendation beats an opaque one; unexplainable recommendations SHOULD NOT be shown", "file_type": "rationale", "source_file": "docs/RFC-002.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_rfc_002_ep_007_human_authority", "label": "EP-007 Human Authority: AI recommends, humans decide; AI SHALL NEVER silently send email, delete data, modify data, execute workflows or approve requests", "file_type": "rationale", "source_file": "docs/RFC-002.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_rfc_002_ep_008_permanent_memory", "label": "EP-008 Permanent Memory: information should never be intentionally discarded; system prefers preservation over deletion; summaries regenerate, memory persists", "file_type": "rationale", "source_file": "docs/RFC-002.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_rfc_002_ep_009_modular_architecture", "label": "EP-009 Modular Architecture: subsystems have one responsibility, communicate through contracts; dependency direction UI->Application->Domain->Infrastructure, never reversed", "file_type": "rationale", "source_file": "docs/RFC-002.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_rfc_002_ep_010_evolution_over_perfection", "label": "EP-010 Evolution Over Perfection: choose solutions that evolve safely rather than predicting every future requirement; stability over perfection", "file_type": "rationale", "source_file": "docs/RFC-002.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"i